    "HEALTHKIT_PERMISSIONS_DESCRIPTION" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "My Heart Counts needs read-access to automatically collect data such as heart rate, step counts, active calories, sleep durations, etc. Further, granting write-access will give the best user experience with the application for dashboard features. To enhance research and optimize user experience, select **“Turn On All”**.\n\nWe are committed to protecting your privacy. Your data will be securely shared only among the My Heart Counts Research Team and our trusted research partners. Any data shared publicly will be thoroughly de-identified to ensure it cannot be traced back to you. Additionally, we require all external researchers to prove their qualifications and obtain approval before accessing any shared data for their studies.\n\nYou can revoke this access at any time."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "My Heart Counts needs read-access to automatically collect data such as heart rate, step counts, active calories, sleep durations, etc. Further, granting write-access will give the best user experience with the application for dashboard features. To enhance research and optimize user experience, select **“Turn On All”**.\n\nWe are committed to protecting your privacy. Your data will be securely shared only among the My Heart Counts Research Team and our trusted research partners. Any data shared publicly will be thoroughly de-identified to ensure it cannot be traced back to you. Additionally, we require all external researchers to prove their qualifications and obtain approval before accessing any shared data for their studies.\n\nYou can revoke this access at any time."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "My Heart Counts necesita acceso de lectura para recopilar automáticamente datos como frecuencia cardíaca, conteos de pasos, calorías activas, duraciones de sueño, etc. Además, otorgar acceso de escritura brindará la mejor experiencia de uso de la aplicación para las funciones del panel. Para potenciar la investigación y optimizar la experiencia del usuario, seleccione **“Activar todo”**.\n\nEstamos comprometidos con la protección de su privacidad. Sus datos se compartirán de forma segura únicamente entre el Equipo de Investigación de My Heart Counts y nuestros socios de investigación de confianza. Cualquier dato que se comparta públicamente será minuciosamente desidentificado para garantizar que no pueda vincularse con usted. Además, exigimos que todos los investigadores externos acrediten sus calificaciones y obtengan la aprobación antes de acceder a cualquier dato compartido para sus estudios.\n\nPuede revocar este acceso en cualquier momento."
          }
        }
      }
    },
    "HEALTHKIT_PERMISSIONS_SUBTITLE" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The My Heart Counts Study uses Health Data collected on your iPhone to further research. Granting access to all fields (or as many as you are comfortable with) ensures the most well powered study possible."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The My Heart Counts Study uses Health Data collected on your iPhone to further research. Granting access to all fields (or as many as you are comfortable with) ensures the most well powered study possible."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
