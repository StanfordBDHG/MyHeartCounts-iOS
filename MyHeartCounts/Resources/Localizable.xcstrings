        }
      }
    },
    "COMPREHENSION_QUESTION_3" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Once I start participating in this study, I can choose to not continue at any time with no repercussions to me."
