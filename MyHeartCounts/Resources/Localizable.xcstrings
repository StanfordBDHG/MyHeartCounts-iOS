    "NOTIFICATION_PERMISSIONS_DESCRIPTION" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Allowing Notifications for My Heart Counts is important because this is where you will be sent prompts from the physical activity promoting trial. In order to carry out research goals, this is an important step that we ask participants to grant access to. \n\nParticipants will also be sent notifications about new surveys, activities, etc.\n\nWe will do our best to keep the notifications to a minimum."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Allowing Notifications for My Heart Counts is important because this is where you will be sent prompts from the physical activity promoting trial. In order to carry out research goals, this is an important step that we ask participants to grant access to. \n\nParticipants will also be sent notifications about new surveys, activities, etc.\n\nWe will do our best to keep the notifications to a minimum."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Permitir las notificaciones de My Heart Counts es importante, ya que por este medio recibirá indicaciones del ensayo de promoción de la actividad física. Para cumplir los objetivos de investigación, le solicitamos que conceda este permiso.\n\nTambién le enviaremos notificaciones sobre nuevas encuestas, actividades, etc.\n\nHaremos todo lo posible por mantener las notificaciones al mínimo."
          }
        }
      }
    },
