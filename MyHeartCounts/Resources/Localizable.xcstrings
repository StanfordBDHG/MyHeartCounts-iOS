          }
        }
      }
    },
    "COMPREHENSION_QUESTION_2" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "I am not required to complete all or any parts of this study if I don’t want to."
