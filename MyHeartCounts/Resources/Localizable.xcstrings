        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Experience the re-designed version of one of the largest research study applications ever."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Experimenta la versión rediseñada de una de las aplicaciones de estudios de investigación más grandes jamás realizadas."
          }
        }
      }
    },
    "WELCOME_AREA3_DESCRIPTION" : {
      "localizations" : {
